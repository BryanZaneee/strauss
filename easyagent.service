[Unit]
Description=EasyAgent AI Agent Backend
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/opt/easyagent
Environment="PATH=/opt/easyagent/.venv/bin"
ExecStart=/opt/easyagent/.venv/bin/python -m uvicorn backend.app:app --port 8001
Restart=always

[Install]
WantedBy=multi-user.target

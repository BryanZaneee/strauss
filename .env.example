# --- LLM provider keys (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- App config ---
# EasyAgent reads its KB and profiles from these roots. The bundled `strauss`
# example profile is the default.
EASYAGENT_KB_ROOT=./kb
EASYAGENT_PROFILE_ROOT=./profiles
DEFAULT_PROFILE=strauss
DEFAULT_MODEL=deepseek-v4-flash

# --- Limits ---
DAILY_TOKEN_BUDGET=5000000
SESSION_TTL_SECONDS=1800
MAX_TURNS_PER_SESSION=40
MAX_TOOL_HOPS=8
MAX_ACTIVE_SESSIONS=200

# --- Abuse protection ---
RATE_LIMIT_CHAT=10/minute;100/hour
RATE_LIMIT_ENABLED=1
LOG_LEVEL=INFO

# --- CORS (dev) ---
ALLOWED_ORIGINS=http://localhost:8000
